{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate --schema=../../packages/database/prisma/schema.prisma",
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.cjs --external:@prisma/client --external:pg --external:@prisma/adapter-pg",
    "start": "node dist/index.cjs",
    "migrate": "prisma migrate deploy --schema=../../packages/database/prisma/schema.prisma",
    "test": "node --env-file=.env --import tsx/esm --test tests/integration.test.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sendgrid/mail": "^8.1.6",
    "hono": "^4.7.11",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0"
  }
}

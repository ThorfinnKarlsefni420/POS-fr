{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@prisma/client",
    "start": "node dist/index.js",
    "migrate": "prisma migrate deploy --schema=../packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@prisma/client": "^7.8.0",
    "@sendgrid/mail": "^8.1.6",
    "hono": "^4.7.11"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "dotenv": "^17.4.2",
    "esbuild": "^0.27.7",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0"
  }
}

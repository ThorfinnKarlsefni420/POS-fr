# PostgreSQL connection string
# Supabase: Settings → Database → Connection string (Transaction Pooler mode, port 6543)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"

# Port the API listens on (default 3001)
PORT=3001

# Comma-separated list of allowed frontend origins
# Example: https://pos.yourdomain.com,https://www.pos.yourdomain.com
CORS_ORIGIN="https://YOUR_FRONTEND_URL"

# Twilio SendGrid — transactional email
# Get your key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG.xxx..."
SENDGRID_FROM_EMAIL="onboarding@yourdomain.com"

# SerpApi — Google Image Search
# Get your key at https://serpapi.com/
SERPAPI_KEY="your_serpapi_key_here"

# Cloudinary Server Credentials
# Found in Cloudinary Dashboard → Account Details
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
CLOUDINARY_CLOUD_NAME="your_cloud_name"

# AssemblyAI — real-time streaming transcription + LeMUR intent extraction (voice assist feature)
# Get your key at https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY="your_assemblyai_api_key_here"

# Credentials encryption key — protects D365 / integration secrets in the DB
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY="64_char_hex_string_here"

# ─── KRA eTIMS — Kenya Tax Invoice Management System ────────────────────────
# Registration: https://etims.kra.go.ke
#
# How to register:
#   1. Go to https://etims.kra.go.ke and click "Register"
#   2. Log in with your KRA iTax credentials (same PIN + password as itax.kra.go.ke)
#   3. Under "Device Management" → add a new OSCU (Online Sales Control Unit)
#   4. Choose "Virtual OSCU" if you have no physical device
#   5. Complete the initialization request — KRA sends back:
#        - Device Serial Number  → ETIMS_DEVICE_SERIAL
#        - cmcKey (API key)      → ETIMS_API_KEY
#   6. Your KRA PIN             → ETIMS_TAXPAYER_PIN
#   7. Test on sandbox first (ETIMS_ENVIRONMENT=sandbox), then flip to production
#
# The system operates in no-op mode (invoices are skipped with a warning) until
# all three required vars are filled in.
ETIMS_TAXPAYER_PIN="P000000000A"         # your KRA PIN
ETIMS_DEVICE_SERIAL="OSCU12345678"       # assigned by KRA during device registration
ETIMS_API_KEY="your_cmc_key_here"        # cmcKey from KRA initialization response
ETIMS_BRANCH_ID="00"                     # branch ID — "00" for main/only branch
ETIMS_TRADE_NAME="Your Business Name"    # legal name to appear on tax invoices
ETIMS_ENVIRONMENT="sandbox"              # "sandbox" or "production"

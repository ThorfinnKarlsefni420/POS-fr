# PostgreSQL connection string
# Supabase: Settings → Database → Connection string (Transaction Pooler mode, port 6543)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"

# Port the API listens on (default 3001)
PORT=3001

# Comma-separated list of allowed frontend origins
# Example: https://pos.yourdomain.com,https://www.pos.yourdomain.com
CORS_ORIGIN="https://YOUR_FRONTEND_URL"

# Twilio SendGrid — transactional email
# Get your key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG.xxx..."
SENDGRID_FROM_EMAIL="onboarding@yourdomain.com"

# SerpApi — Google Image Search
# Get your key at https://serpapi.com/
SERPAPI_KEY="your_serpapi_key_here"

# Cloudinary Server Credentials
# Found in Cloudinary Dashboard → Account Details
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
CLOUDINARY_CLOUD_NAME="your_cloud_name"

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Multi-Tenant Store ───────────────────────────────────────────────────────

model Store {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  ownerName    String?
  phone        String?
  email        String?
  address      String?
  isActive     Boolean        @default(true)
  users                User[]
  items                Item[]
  shifts               Shift[]
  transactions         Transaction[]
  vendors              Vendor[]
  customers            Customer[]
  purchaseOrders       PurchaseOrder[]
  promos               Promo[]
  settings             StoreSetting[]
  stockLocations       StockLocation[]
  stockTransfers       StockTransfer[]
  warehouseIntegrations WarehouseIntegration[]
  suppliers            Supplier[]
  consignmentSettlements ConsignmentSettlement[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

// ─── Users & Auth ──────────────────────────────────────────────────────────

model User {
  id             String          @id @default(cuid())
  name           String
  pin            String          // 4-digit hashed PIN
  role           Role            @default(CASHIER)
  storeId        String?
  store          Store?          @relation(fields: [storeId], references: [id])
  shifts         Shift[]
  transactions   Transaction[]
  vendorPayments VendorPayment[]
  mkopoPayments  MkopoPayment[]
  supplierId     String?
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum Role {
  SUPERADMIN
  ADMIN
  CASHIER
  SUPPLIER
}

// ─── Shift & Cash Management ────────────────────────────────────────────────

model Shift {
  id           String    @id @default(cuid())
  storeId      String
  store        Store     @relation(fields: [storeId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  startTime    DateTime  @default(now())
  endTime      DateTime?
  startingCash Decimal   @db.Decimal(10, 2)
  endingCash   Decimal?  @db.Decimal(10, 2)
  actualCash   Decimal?  @db.Decimal(10, 2)
  cashLogs     CashLog[]
  transactions Transaction[]
  createdAt    DateTime  @default(now())
}

model CashLog {
  id        String      @id @default(cuid())
  shiftId   String
  shift     Shift       @relation(fields: [shiftId], references: [id])
  amount    Decimal     @db.Decimal(10, 2)
  type      CashLogType
  reason    String
  createdAt DateTime    @default(now())
}

enum CashLogType {
  PAY_IN
  PAY_OUT
}

// ─── VAT Engine ───────────────────────────────────────────────────────────────

model VatClass {
  id               String        @id
  code             String        @unique  // 'STANDARD' | 'ZERO' | 'EXEMPT'
  label            String
  rate             Decimal       @db.Decimal(5, 4)  // 0.1600 / 0.0000
  etimsCode        String                            // 'VAT' | 'ZERO' | 'NONTAXABLE'
  kraRef           String?
  canClaimInputVat Boolean       @default(false)
  categoryVats     CategoryVat[]
  items            Item[]
}

model CategoryVat {
  id           String    @id @default(cuid())
  category     String    @unique
  vatClassId   String
  vatClass     VatClass  @relation(fields: [vatClassId], references: [id])
  hasOverrides Boolean   @default(false)
  notes        String?
}

// ─── Inventory ───────────────────────────────────────────────────────────────

model Item {
  id               String    @id @default(cuid())
  storeId          String
  store            Store     @relation(fields: [storeId], references: [id])
  name             String
  sku              String
  category         String    @default("")
  subCategory      String    @default("")
  unit             String    @default("")
  boxQty           String    @default("")

  // Pricing
  costPrice        Decimal   @db.Decimal(10, 2)
  sellingPrice     Decimal   @default(0) @db.Decimal(10, 2) // vendor's own retail price
  nomadBitePrice   Decimal   @db.Decimal(10, 2)
  taxRate          Decimal   @default(0) @db.Decimal(5, 2)  // legacy; derived from VatClass.rate * 100

  // VAT
  vatClassId           String?
  vatClass             VatClass? @relation(fields: [vatClassId], references: [id])
  vatOverrideReason    String?
  etimsItemCode        String?
  needsVatConfirmation Boolean   @default(false)

  // Metadata
  description      String?
  notes            String?
  imageUrl         String?
  isFractional     Boolean   @default(false)
  currentStock     Decimal   @default(0) @db.Decimal(12, 3)
  manufacturingDate DateTime?
  expiryDate       DateTime?

  // Supplier info
  barcode          String?
  supplierName     String?
  supplierPhone    String?
  leadTimeDays     Int?
  reorderPoint     Decimal?  @db.Decimal(12, 3)
  reorderQty       Decimal?  @db.Decimal(12, 3)
  supplierId       String?
  supplier         Supplier? @relation(fields: [supplierId], references: [id])

  // Break-bulk hierarchy
  parentItemId     String?
  parentItem       Item?     @relation("ItemHierarchy", fields: [parentItemId], references: [id])
  childItems       Item[]    @relation("ItemHierarchy")

  packagingTiers   PackagingTier[]
  itemStocks       ItemStock[]
  stockTransfers   StockTransfer[]
  lineItems        LineItem[]
  adjustments      InventoryAdjustment[]
  poLines          POLine[]
  promos           Promo[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([storeId, sku])
}

model PackagingTier {
  id                   String   @id @default(cuid())
  itemId               String
  item                 Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name                 String   // "Piece", "Outer", "Carton", "Bale", or custom
  level                Int      // ordering: 0 = base unit, 1 = outer, 2 = carton, 3 = bale, etc.
  quantityInBase       Decimal  @db.Decimal(12, 3) // how many base units fit in this tier
  costPrice            Decimal  @db.Decimal(10, 2) // buying cost per unit of THIS tier
  sellingPriceOverride Decimal? @db.Decimal(10, 2) // optional override (bulk / carton price)
  barcode              String?  // tier-specific barcode for scanning
  isBaseUnit           Boolean  @default(false)    // the tier sold individually at POS
  roundingPrecision    Decimal  @default(0.001) @db.Decimal(10, 6) // base-unit qty is rounded to this step after conversion
  stockTransfers       StockTransfer[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([itemId, name])
  @@unique([itemId, level])
}

// ─── Multi-Location Stock ─────────────────────────────────────────────────────

enum LocationType {
  WAREHOUSE
  SHELF
  DISPLAY
  TRANSIT
  OTHER
}

model StockLocation {
  id            String         @id @default(cuid())
  storeId       String
  store         Store          @relation(fields: [storeId], references: [id])
  name          String
  type          LocationType   @default(WAREHOUSE)
  description   String?
  isActive      Boolean        @default(true)
  itemStocks    ItemStock[]
  transfersFrom StockTransfer[] @relation("TransferFrom")
  transfersTo   StockTransfer[] @relation("TransferTo")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([storeId, name])
}

model ItemStock {
  id         String        @id @default(cuid())
  itemId     String
  item       Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  locationId String
  location   StockLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  quantity   Decimal       @default(0) @db.Decimal(12, 3)
  updatedAt  DateTime      @updatedAt

  @@unique([itemId, locationId])
}

model StockTransfer {
  id              String         @id @default(cuid())
  storeId         String
  store           Store          @relation(fields: [storeId], references: [id])
  itemId          String
  item            Item           @relation(fields: [itemId], references: [id])
  fromLocationId  String?
  fromLocation    StockLocation? @relation("TransferFrom", fields: [fromLocationId], references: [id])
  toLocationId    String?
  toLocation      StockLocation? @relation("TransferTo", fields: [toLocationId], references: [id])
  quantityBase    Decimal        @db.Decimal(12, 3)
  packagingTierId String?
  packagingTier   PackagingTier? @relation(fields: [packagingTierId], references: [id])
  quantityInTier  Decimal?       @db.Decimal(12, 3)
  reason          String?
  notes           String?
  performedById   String?
  createdAt       DateTime       @default(now())
}

// ─── Transactions ────────────────────────────────────────────────────────────

model Transaction {
  id               String      @id @default(cuid())
  storeId          String
  store            Store       @relation(fields: [storeId], references: [id])
  shiftId          String
  shift            Shift       @relation(fields: [shiftId], references: [id])
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  totalAmount      Decimal     @db.Decimal(10, 2)
  taxAmount        Decimal     @default(0) @db.Decimal(10, 2)  // total VAT extracted (Standard 16% lines only)
  totalZeroKes     Decimal     @default(0) @db.Decimal(10, 2)  // sum of Zero-Rated line totals
  totalExemptKes   Decimal     @default(0) @db.Decimal(10, 2)  // sum of Exempt line totals
  paymentType      PaymentType
  status           TxStatus    @default(COMPLETED)
  etimsReceiptNo   String?
  etimsQrCode      String?
  submittedToEtims Boolean     @default(false)
  lineItems        LineItem[]
  creditSale       CreditSale?
  mkopoSale        MkopoSale?
  splitPayments    TransactionPayment[]
  splitChange      Decimal?    @db.Decimal(10, 2)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model TransactionPayment {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  method        String      // 'CASH' | 'MPESA' | 'CARD'
  amount        Decimal     @db.Decimal(10, 2)
  createdAt     DateTime    @default(now())
}

enum PaymentType {
  CASH
  CARD
  MPESA
  CREDIT
  MKOPO
  SPLIT
}

enum TxStatus {
  COMPLETED
  VOIDED
  REFUNDED
}

model LineItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  itemId        String
  item          Item        @relation(fields: [itemId], references: [id])
  quantity      Decimal     @db.Decimal(12, 3)
  originalPrice Decimal     @db.Decimal(10, 2) // nomadBitePrice at time of sale
  soldPrice     Decimal     @db.Decimal(10, 2) // actual price charged (may differ if overridden)
  discountReason String?
  isReturned    Boolean     @default(false)
  isDamaged     Boolean     @default(false)
  // VAT snapshot — values at time of sale, never recomputed
  vatRate       Decimal     @default(0)    @db.Decimal(5, 4)   // 0.1600 or 0.0000
  etimsCode     String      @default("VAT")                    // 'VAT' | 'ZERO' | 'NONTAXABLE'
  vatAmount     Decimal     @default(0)    @db.Decimal(10, 2)  // per-unit VAT extracted
  netAmount     Decimal     @default(0)    @db.Decimal(10, 2)  // per-unit net excl. VAT
  consignmentSale ConsignmentSale?
  createdAt     DateTime    @default(now())
}

model InventoryAdjustment {
  id         String     @id @default(cuid())
  itemId     String
  item       Item       @relation(fields: [itemId], references: [id])
  quantity   Decimal    @db.Decimal(12, 3)
  reasonCode AdjustReason
  note       String?
  createdAt  DateTime   @default(now())
}

enum AdjustReason {
  DAMAGED
  STOLEN
  EXPIRED
  PROMO
  RESTOCK
  RECOUNT
}

// ─── Global System Settings (superadmin-only) ────────────────────────────────

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Store Settings ───────────────────────────────────────────────────────────

model StoreSetting {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([storeId, key])
}

// ─── Vendor Credit ────────────────────────────────────────────────────────────

model Vendor {
  id          String       @id @default(cuid())
  storeId     String
  store       Store        @relation(fields: [storeId], references: [id])
  name        String
  phone       String?
  email       String?
  creditLimit Decimal      @default(0) @db.Decimal(10, 2)
  creditSales CreditSale[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CreditSale {
  id            String          @id @default(cuid())
  vendorId      String
  vendor        Vendor          @relation(fields: [vendorId], references: [id])
  transactionId String          @unique
  transaction   Transaction     @relation(fields: [transactionId], references: [id])
  amountOwed    Decimal         @db.Decimal(10, 2)
  amountPaid    Decimal         @default(0) @db.Decimal(10, 2)
  dueDate       DateTime
  status        CreditStatus    @default(UNPAID)
  payments      VendorPayment[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model VendorPayment {
  id           String              @id @default(cuid())
  creditSaleId String
  creditSale   CreditSale          @relation(fields: [creditSaleId], references: [id])
  amount       Decimal             @db.Decimal(10, 2)
  method       VendorPaymentMethod
  recordedById String
  recordedBy   User                @relation(fields: [recordedById], references: [id])
  note         String?
  paidAt       DateTime            @default(now())
}

enum CreditStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

enum VendorPaymentMethod {
  CASH
  MPESA
  BANK_TRANSFER
}

// ─── Purchase Orders ──────────────────────────────────────────────────────────

enum POStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id])
  referenceNo String?
  vendorName  String?
  status      POStatus  @default(DRAFT)
  expectedAt  DateTime?
  notes       String?
  lines       POLine[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model POLine {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item          @relation(fields: [itemId], references: [id])
  tierId      String?
  orderedQty  Decimal       @db.Decimal(12, 3)
  receivedQty Decimal       @default(0) @db.Decimal(12, 3)
  unitCost    Decimal       @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime      @default(now())
}

// ─── Promotions ───────────────────────────────────────────────────────────────

enum PromoType {
  PERCENT_OFF
  FIXED_OFF
  BOGO
}

enum PromoScope {
  ALL
  CATEGORY
  ITEM
}

model Promo {
  id           String     @id @default(cuid())
  storeId      String
  store        Store      @relation(fields: [storeId], references: [id])
  name         String
  type         PromoType
  value        Decimal    @db.Decimal(10, 4)
  scope        PromoScope @default(ALL)
  categoryName String?
  itemId       String?
  item         Item?      @relation(fields: [itemId], references: [id], onDelete: SetNull)
  minQty       Int        @default(1)
  minAmount    Decimal    @default(0) @db.Decimal(10, 2)
  buyQty       Int?
  getQty       Int?
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ─── Consumer Credit (Mkopo) ──────────────────────────────────────────────────

model Customer {
  id          String       @id @default(cuid())
  storeId     String
  store       Store        @relation(fields: [storeId], references: [id])
  name        String
  phone       String?
  email       String?
  creditLimit Decimal      @default(0) @db.Decimal(10, 2)
  mkopoSales  MkopoSale[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([storeId, phone])
}

model MkopoSale {
  id            String         @id @default(cuid())
  customerId    String
  customer      Customer       @relation(fields: [customerId], references: [id])
  transactionId String         @unique
  transaction   Transaction    @relation(fields: [transactionId], references: [id])
  amountOwed    Decimal        @db.Decimal(10, 2)
  amountPaid    Decimal        @default(0) @db.Decimal(10, 2)
  dueDate       DateTime?
  status        MkopoStatus    @default(UNPAID)
  payments      MkopoPayment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model MkopoPayment {
  id           String              @id @default(cuid())
  mkopoSaleId  String
  mkopoSale    MkopoSale           @relation(fields: [mkopoSaleId], references: [id])
  amount       Decimal             @db.Decimal(10, 2)
  method       VendorPaymentMethod
  recordedById String
  recordedBy   User                @relation(fields: [recordedById], references: [id])
  note         String?
  paidAt       DateTime            @default(now())
}

enum MkopoStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

// ─── Consignment (Pay-on-Sell) ────────────────────────────────────────────────

enum ConsignmentType {
  FIXED_COST
  PERCENTAGE_COMMISSION
  HYBRID
}

enum SettlementStatus {
  UNPAID
  PAID
}

enum ConsignmentSaleStatus {
  PENDING
  SETTLED
  VOIDED
}

model Supplier {
  id               String                @id @default(cuid())
  storeId          String
  store            Store                 @relation(fields: [storeId], references: [id])
  name             String
  phone            String?
  email            String?
  isConsignment    Boolean               @default(false)
  defaultType      ConsignmentType       @default(FIXED_COST)
  defaultRate      Decimal               @default(0) @db.Decimal(10, 4)
  hybridConfig     Json?                 // extensible config for HYBRID settlement formulas
  items            Item[]
  consignmentSales ConsignmentSale[]
  settlements      ConsignmentSettlement[]
  users            User[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([storeId, name])
}

model ConsignmentSale {
  id               String                @id @default(cuid())
  lineItemId       String                @unique
  lineItem         LineItem              @relation(fields: [lineItemId], references: [id])
  supplierId       String
  supplier         Supplier              @relation(fields: [supplierId], references: [id])
  // Snapshot of settlement config at time of sale — never recalculate from live supplier config
  settlementType   ConsignmentType       @default(PERCENTAGE_COMMISSION)
  settlementRate   Decimal?              @db.Decimal(10, 4)
  payoutAmount     Decimal               @db.Decimal(10, 2) // equals supplierAmount (kept for settlement rollup)
  supplierAmount   Decimal               @db.Decimal(10, 2) @default(0)
  superadminAmount Decimal               @db.Decimal(10, 2) @default(0) // store's profit (remainder)
  status           ConsignmentSaleStatus @default(PENDING)
  settlementId     String?
  settlement       ConsignmentSettlement? @relation(fields: [settlementId], references: [id])
  createdAt        DateTime              @default(now())
}

model ConsignmentSettlement {
  id               String           @id @default(cuid())
  storeId          String
  store            Store            @relation(fields: [storeId], references: [id])
  supplierId       String
  supplier         Supplier         @relation(fields: [supplierId], references: [id])
  totalAmount      Decimal          @db.Decimal(10, 2)
  supplierAmount   Decimal          @db.Decimal(10, 2) @default(0)
  superadminAmount Decimal          @db.Decimal(10, 2) @default(0)
  status           SettlementStatus @default(UNPAID)
  superadminStatus SettlementStatus @default(UNPAID)
  sales            ConsignmentSale[]
  paidAt           DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

// ─── Warehouse Integration Plugin ─────────────────────────────────────────────

enum IntegrationType {
  CSV
  WEBHOOK
  REST_API
  ODOO
  QUICKBOOKS
  SAGE
  DYNAMICS_365
}

enum SyncDirection {
  INBOUND
  OUTBOUND
}

enum SyncStatus {
  SUCCESS
  PARTIAL
  FAILED
}

model WarehouseIntegration {
  id            String               @id @default(cuid())
  storeId       String
  store         Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name          String
  type          IntegrationType
  syncDirection SyncDirection        @default(INBOUND)
  credentials   Json                 @default("{}")
  fieldMappings Json                 @default("[]")
  webhookSecret String?              @unique
  isActive      Boolean              @default(false)
  lastSyncAt    DateTime?
  syncLogs      IntegrationSyncLog[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([storeId, name])
}

model IntegrationSyncLog {
  id             String               @id @default(cuid())
  integrationId  String
  integration    WarehouseIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  status         SyncStatus
  rowsProcessed  Int                  @default(0)
  rowsSucceeded  Int                  @default(0)
  rowsFailed     Int                  @default(0)
  errorMessage   String?
  details        Json?
  createdAt      DateTime             @default(now())
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-Tenant Store ───────────────────────────────────────────────────────

model Store {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  ownerName    String?
  phone        String?
  email        String?
  address      String?
  isActive     Boolean        @default(true)
  users        User[]
  items        Item[]
  shifts       Shift[]
  transactions Transaction[]
  vendors      Vendor[]
  settings     StoreSetting[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// ─── Users & Auth ──────────────────────────────────────────────────────────

model User {
  id             String          @id @default(cuid())
  name           String
  pin            String          // 4-digit hashed PIN
  role           Role            @default(CASHIER)
  storeId        String?
  store          Store?          @relation(fields: [storeId], references: [id])
  shifts         Shift[]
  transactions   Transaction[]
  vendorPayments VendorPayment[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum Role {
  SUPERADMIN
  ADMIN
  CASHIER
}

// ─── Shift & Cash Management ────────────────────────────────────────────────

model Shift {
  id           String    @id @default(cuid())
  storeId      String
  store        Store     @relation(fields: [storeId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  startTime    DateTime  @default(now())
  endTime      DateTime?
  startingCash Decimal   @db.Decimal(10, 2)
  endingCash   Decimal?  @db.Decimal(10, 2)
  actualCash   Decimal?  @db.Decimal(10, 2)
  cashLogs     CashLog[]
  transactions Transaction[]
  createdAt    DateTime  @default(now())
}

model CashLog {
  id        String      @id @default(cuid())
  shiftId   String
  shift     Shift       @relation(fields: [shiftId], references: [id])
  amount    Decimal     @db.Decimal(10, 2)
  type      CashLogType
  reason    String
  createdAt DateTime    @default(now())
}

enum CashLogType {
  PAY_IN
  PAY_OUT
}

// ─── Inventory ───────────────────────────────────────────────────────────────

model Item {
  id               String    @id @default(cuid())
  storeId          String
  store            Store     @relation(fields: [storeId], references: [id])
  name             String
  sku              String
  category         String    @default("")
  subCategory      String    @default("")
  unit             String    @default("")
  boxQty           String    @default("")

  // Pricing
  costPrice        Decimal   @db.Decimal(10, 2)
  sellingPrice     Decimal   @default(0) @db.Decimal(10, 2) // vendor's own retail price
  nomadBitePrice   Decimal   @db.Decimal(10, 2)
  taxRate          Decimal   @default(0) @db.Decimal(5, 2)

  // Metadata
  description      String?
  notes            String?
  imageUrl         String?
  isFractional     Boolean   @default(false)
  currentStock     Decimal   @default(0) @db.Decimal(12, 3)
  manufacturingDate DateTime?
  expiryDate       DateTime?

  // Break-bulk hierarchy
  parentItemId     String?
  parentItem       Item?     @relation("ItemHierarchy", fields: [parentItemId], references: [id])
  childItems       Item[]    @relation("ItemHierarchy")

  lineItems        LineItem[]
  adjustments      InventoryAdjustment[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([storeId, sku])
}

// ─── Transactions ────────────────────────────────────────────────────────────

model Transaction {
  id          String      @id @default(cuid())
  storeId     String
  store       Store       @relation(fields: [storeId], references: [id])
  shiftId     String
  shift       Shift       @relation(fields: [shiftId], references: [id])
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  totalAmount Decimal     @db.Decimal(10, 2)
  taxAmount   Decimal     @default(0) @db.Decimal(10, 2)
  paymentType PaymentType
  status      TxStatus    @default(COMPLETED)
  lineItems   LineItem[]
  creditSale  CreditSale?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum PaymentType {
  CASH
  CARD
  MPESA
  CREDIT
}

enum TxStatus {
  COMPLETED
  VOIDED
  REFUNDED
}

model LineItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  itemId        String
  item          Item        @relation(fields: [itemId], references: [id])
  quantity      Decimal     @db.Decimal(12, 3)
  originalPrice Decimal     @db.Decimal(10, 2) // nomadBitePrice at time of sale
  soldPrice     Decimal     @db.Decimal(10, 2) // actual price charged (may differ if overridden)
  discountReason String?
  isReturned    Boolean     @default(false)
  isDamaged     Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

model InventoryAdjustment {
  id         String     @id @default(cuid())
  itemId     String
  item       Item       @relation(fields: [itemId], references: [id])
  quantity   Decimal    @db.Decimal(12, 3)
  reasonCode AdjustReason
  note       String?
  createdAt  DateTime   @default(now())
}

enum AdjustReason {
  DAMAGED
  STOLEN
  EXPIRED
  PROMO
  RESTOCK
  RECOUNT
}

// ─── Global System Settings (superadmin-only) ────────────────────────────────

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Store Settings ───────────────────────────────────────────────────────────

model StoreSetting {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([storeId, key])
}

// ─── Vendor Credit ────────────────────────────────────────────────────────────

model Vendor {
  id          String       @id @default(cuid())
  storeId     String
  store       Store        @relation(fields: [storeId], references: [id])
  name        String
  phone       String?
  email       String?
  creditLimit Decimal      @default(0) @db.Decimal(10, 2)
  creditSales CreditSale[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CreditSale {
  id            String          @id @default(cuid())
  vendorId      String
  vendor        Vendor          @relation(fields: [vendorId], references: [id])
  transactionId String          @unique
  transaction   Transaction     @relation(fields: [transactionId], references: [id])
  amountOwed    Decimal         @db.Decimal(10, 2)
  amountPaid    Decimal         @default(0) @db.Decimal(10, 2)
  dueDate       DateTime
  status        CreditStatus    @default(UNPAID)
  payments      VendorPayment[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model VendorPayment {
  id           String              @id @default(cuid())
  creditSaleId String
  creditSale   CreditSale          @relation(fields: [creditSaleId], references: [id])
  amount       Decimal             @db.Decimal(10, 2)
  method       VendorPaymentMethod
  recordedById String
  recordedBy   User                @relation(fields: [recordedById], references: [id])
  note         String?
  paidAt       DateTime            @default(now())
}

enum CreditStatus {
  UNPAID
  PARTIAL
  PAID
  OVERDUE
}

enum VendorPaymentMethod {
  CASH
  MPESA
  BANK_TRANSFER
}
